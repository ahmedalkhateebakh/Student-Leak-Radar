# =========================================================
# System / Cache Files
# =========================================================
.ipynb_checkpoints/
__pycache__/
*.pyc
.DS_Store
Thumbs.db

# =========================================================
# Virtual Environment
# =========================================================
venv/
.env/
.venv/

# =========================================================
# Large / Raw Data
# =========================================================
data/raw/
data/processed/

project/data/raw/
project/data/processed/

*.zip

# =========================================================
# Ignore ALL CSV files by default
# =========================================================
*.csv

# =========================================================
# Allow ONLY processed datasets inside notebooks
# =========================================================
!project/notebooks/data/processed/
!project/notebooks/data/processed/*.csv

# =========================================================
# Ignore Tests Folder
# =========================================================
project/tests/

# =========================================================
# Keep Main Notebooks
# =========================================================
!project/notebooks/

# =========================================================
# Optional: Ignore notebook outputs cache
# =========================================================
*.nbconvert.ipynb